#!/usr/bin/env python3
"""
dictfix — CLI for managing macOS dictation/speech-to-text corrections.

PURPOSE:
    macOS speech-to-text (dictation) often transcribes words incorrectly,
    especially with accents or technical vocabulary. dictfix manages a
    correction list powered by espanso (a local, open-source text expander)
    so that misheard words are automatically replaced the instant they
    appear — in any app, including Terminal and VS Code.

    Corrections are stored in ~/.config/espanso/match/dictation-fixes.yml
    and espanso is automatically restarted when corrections change.

PREREQUISITES:
    brew install espanso
    # Grant Accessibility + Input Monitoring permissions in System Settings

USAGE:
    dictfix add <wrong> <correct>       Add or update a correction
    dictfix remove <wrong>              Remove a correction (alias: rm)
    dictfix list                        List all corrections (alias: ls)
    dictfix search <term>               Search corrections (alias: find)
    dictfix import <csv_file>           Bulk import from CSV (wrong,correct per line)
    dictfix export [csv_file]           Export to CSV (stdout if no file given)
    dictfix test <text>                 Preview corrections applied to text
    dictfix doctor                      Check system settings for optimal dictation accuracy
    dictfix help                        Show this help (alias: -h, --help)

EXAMPLES:
    dictfix add "Contant" "content"     # Fix a persistent dictation error
    dictfix add "Vendable" "vendable"   # Fix capitalization of a brand name
    dictfix rm "Contant"                # Remove a correction
    dictfix ls                          # Show all active corrections
    dictfix find "cont"                 # Search by partial match
    dictfix test "The Contant is ready" # Dry-run: see what would change
    dictfix import ~/fixes.csv          # Bulk load from CSV
    dfx add "gonna" "going to"          # dfx is a shell alias for dictfix

DATA:
    Corrections file : ~/.config/espanso/match/dictation-fixes.yml
    Espanso config   : ~/.config/espanso/config/default.yml

SOURCE:
    https://github.com/crankd/dictfix
"""

import json
import platform
import subprocess
import sys
import os
import re
import csv
import shutil

VERSION = "1.3.1"

FIXES_FILE = os.path.expanduser("~/.config/espanso/match/dictation-fixes.yml")

HEADER = """# Dictation Fixes — Speech-to-text corrections
# Managed by: dictfix CLI — https://github.com/crankd/dictfix
#
# Each entry corrects a known dictation error.
# - trigger: the wrong word that dictation produces
# - replace: the correct word you intended
# - word: true ensures only whole words are matched
# - propagate_case: true preserves capitalization
#
# To add new corrections:
#   dictfix add "wrong" "correct"
#   dfx add "wrong" "correct"

matches:
"""

ENTRY_TEMPLATE = """  - trigger: "{trigger}"
    replace: "{replace}"
    propagate_case: true
    word: true
"""


def parse_entries():
    """Parse existing corrections from the YAML file."""
    entries = []
    if not os.path.exists(FIXES_FILE):
        return entries

    with open(FIXES_FILE, "r") as f:
        content = f.read()

    trigger_pattern = re.compile(r'- trigger:\s*"([^"]+)"')
    replace_pattern = re.compile(r'replace:\s*"([^"]+)"')

    triggers = trigger_pattern.findall(content)
    replaces = replace_pattern.findall(content)

    for t, r in zip(triggers, replaces):
        entries.append({"trigger": t, "replace": r})

    return entries


def write_entries(entries):
    """Write all corrections to the YAML file."""
    content = HEADER
    for entry in sorted(entries, key=lambda e: e["trigger"].lower()):
        content += ENTRY_TEMPLATE.format(
            trigger=entry["trigger"], replace=entry["replace"]
        )

    os.makedirs(os.path.dirname(FIXES_FILE), exist_ok=True)
    with open(FIXES_FILE, "w") as f:
        f.write(content)


def restart_espanso():
    """Restart espanso to apply changes. Silent if espanso is not running."""
    espanso = shutil.which("espanso")
    if not espanso:
        print("  (espanso not found — install with: brew install espanso)")
        return

    try:
        result = subprocess.run(
            [espanso, "restart"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        if result.returncode == 0:
            print("  espanso restarted — corrections are live.")
        else:
            # espanso may not be running yet
            subprocess.run(
                [espanso, "start"],
                capture_output=True,
                text=True,
                timeout=10,
            )
            print("  espanso started — corrections are live.")
    except (subprocess.TimeoutExpired, FileNotFoundError):
        print("  (could not restart espanso — try: espanso restart)")


def cmd_add(wrong, correct):
    """Add a new dictation correction."""
    entries = parse_entries()

    for entry in entries:
        if entry["trigger"].lower() == wrong.lower():
            old_replace = entry["replace"]
            entry["replace"] = correct
            write_entries(entries)
            print(f'Updated: "{wrong}" -> "{correct}" (was "{old_replace}")')
            restart_espanso()
            return

    entries.append({"trigger": wrong, "replace": correct})
    write_entries(entries)
    print(f'Added: "{wrong}" -> "{correct}"')
    print(f"Total corrections: {len(entries)}")
    restart_espanso()


def cmd_remove(wrong):
    """Remove a dictation correction."""
    entries = parse_entries()
    original_count = len(entries)
    entries = [e for e in entries if e["trigger"].lower() != wrong.lower()]

    if len(entries) == original_count:
        print(f'Not found: "{wrong}"')
        sys.exit(1)

    write_entries(entries)
    print(f'Removed: "{wrong}"')
    print(f"Total corrections: {len(entries)}")
    restart_espanso()


def cmd_list():
    """List all corrections."""
    entries = parse_entries()
    if not entries:
        print("No corrections configured yet.")
        print('Add one with: dictfix add "wrong" "correct"')
        return

    max_trigger = max(len(e["trigger"]) for e in entries)
    max_replace = max(len(e["replace"]) for e in entries)

    print(f"{'DICTATED':<{max_trigger + 2}} {'CORRECTED':<{max_replace + 2}}")
    print(f"{'─' * (max_trigger + 2)} {'─' * (max_replace + 2)}")
    for entry in sorted(entries, key=lambda e: e["trigger"].lower()):
        print(
            f"{entry['trigger']:<{max_trigger + 2}} {entry['replace']:<{max_replace + 2}}"
        )
    print(f"\nTotal: {len(entries)} correction(s)")


def cmd_search(term):
    """Search corrections by trigger or replacement."""
    entries = parse_entries()
    term_lower = term.lower()
    matches = [
        e
        for e in entries
        if term_lower in e["trigger"].lower() or term_lower in e["replace"].lower()
    ]

    if not matches:
        print(f'No corrections matching "{term}"')
        return

    max_trigger = max(len(e["trigger"]) for e in matches)
    for entry in matches:
        print(f"{entry['trigger']:<{max_trigger + 2}} -> {entry['replace']}")
    print(f"\n{len(matches)} match(es)")


def cmd_import(csv_file):
    """Import corrections from a CSV file (wrong,correct per line)."""
    if not os.path.exists(csv_file):
        print(f"File not found: {csv_file}")
        sys.exit(1)

    entries = parse_entries()
    existing_triggers = {e["trigger"].lower() for e in entries}
    added = 0
    updated = 0

    with open(csv_file, "r") as f:
        reader = csv.reader(f)
        for row in reader:
            if len(row) < 2:
                continue
            wrong, correct = row[0].strip(), row[1].strip()
            if not wrong or not correct:
                continue

            if wrong.lower() in existing_triggers:
                for e in entries:
                    if e["trigger"].lower() == wrong.lower():
                        e["replace"] = correct
                        updated += 1
                        break
            else:
                entries.append({"trigger": wrong, "replace": correct})
                existing_triggers.add(wrong.lower())
                added += 1

    write_entries(entries)
    print(f"Imported: {added} added, {updated} updated")
    print(f"Total corrections: {len(entries)}")
    restart_espanso()


def cmd_export(csv_file=None):
    """Export corrections to CSV."""
    entries = parse_entries()
    if not entries:
        print("No corrections to export.")
        return

    if csv_file:
        with open(csv_file, "w", newline="") as f:
            writer = csv.writer(f)
            for entry in sorted(entries, key=lambda e: e["trigger"].lower()):
                writer.writerow([entry["trigger"], entry["replace"]])
        print(f"Exported {len(entries)} corrections to {csv_file}")
    else:
        for entry in sorted(entries, key=lambda e: e["trigger"].lower()):
            print(f"{entry['trigger']},{entry['replace']}")


def cmd_test(text):
    """Preview how corrections would be applied to text."""
    entries = parse_entries()
    corrected = text
    changes = []

    for entry in entries:
        pattern = re.compile(
            r"\b" + re.escape(entry["trigger"]) + r"\b", re.IGNORECASE
        )
        if pattern.search(corrected):
            corrected = pattern.sub(entry["replace"], corrected)
            changes.append(f"  {entry['trigger']} -> {entry['replace']}")

    if changes:
        print(f"Original:  {text}")
        print(f"Corrected: {corrected}")
        print(f"\nApplied {len(changes)} correction(s):")
        for c in changes:
            print(c)
    else:
        print("No corrections matched.")


def cmd_doctor():
    """Check system settings for optimal dictation accuracy."""
    print("dictfix doctor — checking macOS dictation settings\n")
    issues = 0
    ok_count = 0

    # 1. Check macOS version
    mac_ver = platform.mac_ver()[0]
    if mac_ver:
        major = int(mac_ver.split(".")[0])
        if major >= 15:
            print(f"  [OK] macOS {mac_ver} (current)")
            ok_count += 1
        elif major >= 13:
            print(f"  [!!] macOS {mac_ver} — consider upgrading for improved dictation accuracy")
            issues += 1
        else:
            print(f"  [!!] macOS {mac_ver} — upgrade recommended (on-device dictation requires 13+)")
            issues += 1
    else:
        print("  [??] Could not detect macOS version")

    # 2. Check Apple Silicon (on-device ML)
    try:
        chip = subprocess.run(
            ["sysctl", "-n", "machdep.cpu.brand_string"],
            capture_output=True, text=True, timeout=5,
        ).stdout.strip()
        if "Apple" in chip:
            print(f"  [OK] Apple Silicon ({chip}) — on-device dictation ML available")
            ok_count += 1
        else:
            print(f"  [..] Intel processor ({chip}) — on-device dictation may be limited")
    except Exception:
        print("  [??] Could not detect processor")

    # 3. Check if dictation is enabled
    try:
        dictation_enabled = subprocess.run(
            ["defaults", "read", "com.apple.HIToolbox", "AppleDictationAutoEnable"],
            capture_output=True, text=True, timeout=5,
        )
        if dictation_enabled.returncode == 0 and dictation_enabled.stdout.strip() == "1":
            print("  [OK] Dictation is enabled")
            ok_count += 1
        else:
            print("  [!!] Dictation may not be enabled")
            print("       -> System Settings > Keyboard > Dictation > toggle ON")
            issues += 1
    except Exception:
        print("  [??] Could not check dictation status")

    # 4. Check dictation language
    try:
        locale_result = subprocess.run(
            ["defaults", "read", "-g", "AppleLocale"],
            capture_output=True, text=True, timeout=5,
        )
        locale = locale_result.stdout.strip() if locale_result.returncode == 0 else "unknown"
        print(f"  [..] System locale: {locale}")
        print("       -> Verify dictation language matches your spoken language in:")
        print("          System Settings > Keyboard > Dictation > Language")
    except Exception:
        pass

    # 5. Check input microphone volume
    try:
        vol_result = subprocess.run(
            ["osascript", "-e", "input volume of (get volume settings)"],
            capture_output=True, text=True, timeout=5,
        )
        if vol_result.returncode == 0:
            vol = int(vol_result.stdout.strip())
            if vol >= 70:
                print(f"  [OK] Microphone input volume: {vol}%")
                ok_count += 1
            elif vol >= 40:
                print(f"  [!!] Microphone input volume: {vol}% — consider increasing to 70%+")
                print("       -> System Settings > Sound > Input > Input volume")
                issues += 1
            else:
                print(f"  [!!] Microphone input volume: {vol}% — too low for reliable dictation")
                print("       -> System Settings > Sound > Input > Input volume")
                issues += 1
    except Exception:
        print("  [??] Could not check microphone volume")

    # 6. Check espanso status
    espanso = shutil.which("espanso")
    if espanso:
        try:
            status = subprocess.run(
                [espanso, "status"], capture_output=True, text=True, timeout=5,
            )
            if status.returncode == 0 and "running" in status.stdout.lower():
                print("  [OK] espanso is running")
                ok_count += 1
            else:
                print("  [!!] espanso is not running")
                print("       -> Run: espanso start")
                issues += 1
        except Exception:
            print("  [??] Could not check espanso status")
    else:
        print("  [!!] espanso is not installed")
        print("       -> Run: brew install espanso")
        issues += 1

    # 7. Check corrections file
    if os.path.exists(FIXES_FILE):
        entries = parse_entries()
        print(f"  [OK] Corrections file exists ({len(entries)} correction(s))")
        ok_count += 1
    else:
        print("  [..] No corrections file yet — add your first with: dictfix add \"wrong\" \"correct\"")

    # 8. Check Accessibility and Input Monitoring (best-effort via tccutil)
    tcc_db = os.path.expanduser("~/Library/Application Support/com.apple.TCC/TCC.db")
    if os.path.exists(tcc_db):
        try:
            import sqlite3
            conn = sqlite3.connect(f"file:{tcc_db}?mode=ro", uri=True)
            cursor = conn.cursor()
            cursor.execute(
                "SELECT service, auth_value FROM access WHERE client LIKE '%espanso%'"
            )
            rows = cursor.fetchall()
            conn.close()
            services_granted = {row[0] for row in rows if row[1] == 2}
            if "kTCCServiceAccessibility" in services_granted:
                print("  [OK] Accessibility permission granted to espanso")
                ok_count += 1
            else:
                print("  [!!] Accessibility permission may not be granted to espanso")
                print("       -> System Settings > Privacy & Security > Accessibility")
                issues += 1
            if "kTCCServiceListenEvent" in services_granted:
                print("  [OK] Input Monitoring permission granted to espanso")
                ok_count += 1
            else:
                print("  [!!] Input Monitoring permission may not be granted to espanso")
                print("       -> System Settings > Privacy & Security > Input Monitoring")
                issues += 1
        except Exception:
            print("  [..] Could not verify espanso permissions (check manually)")
            print("       -> System Settings > Privacy & Security > Accessibility")
            print("       -> System Settings > Privacy & Security > Input Monitoring")
    else:
        print("  [..] Could not verify espanso permissions (check manually)")

    # Summary
    print(f"\n{'─' * 50}")
    if issues == 0:
        print(f"  All checks passed ({ok_count} OK). System looks good for dictation.")
    else:
        print(f"  {ok_count} OK, {issues} issue(s) found.")

    # Tips
    print(f"\n  Tips for better dictation accuracy:")
    print(f"  - Use a headset or external mic in noisy environments")
    print(f"  - Say \"Correct that\" immediately after an error to see alternatives")
    print(f"  - Toggle dictation off/on in System Settings to reset the service")
    print(f"  - Keep macOS updated for the latest speech recognition improvements")
    print(f"  - Re-enable Enhanced Dictation if accuracy degrades over time")
    print(f"    System Settings > Keyboard > Dictation > toggle OFF then ON")


def cmd_help():
    """Print help information."""
    print(__doc__.strip())
    print(f"\nVersion: {VERSION}")


def main():
    if len(sys.argv) < 2:
        cmd_help()
        sys.exit(1)

    command = sys.argv[1].lower()

    if command == "add":
        if len(sys.argv) != 4:
            print('Usage: dictfix add <wrong> <correct>')
            sys.exit(1)
        cmd_add(sys.argv[2], sys.argv[3])

    elif command in ("remove", "rm"):
        if len(sys.argv) != 3:
            print("Usage: dictfix remove <wrong>")
            sys.exit(1)
        cmd_remove(sys.argv[2])

    elif command in ("list", "ls"):
        cmd_list()

    elif command in ("search", "find"):
        if len(sys.argv) != 3:
            print('Usage: dictfix search <term>')
            sys.exit(1)
        cmd_search(sys.argv[2])

    elif command == "import":
        if len(sys.argv) != 3:
            print("Usage: dictfix import <csv_file>")
            sys.exit(1)
        cmd_import(sys.argv[2])

    elif command == "export":
        csv_file = sys.argv[2] if len(sys.argv) > 2 else None
        cmd_export(csv_file)

    elif command == "test":
        if len(sys.argv) < 3:
            print('Usage: dictfix test <text>')
            sys.exit(1)
        cmd_test(" ".join(sys.argv[2:]))

    elif command == "doctor":
        cmd_doctor()

    elif command in ("help", "--help", "-h"):
        cmd_help()

    elif command in ("--version", "-v"):
        print(f"dictfix {VERSION}")

    else:
        print(f"Unknown command: {command}")
        cmd_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
